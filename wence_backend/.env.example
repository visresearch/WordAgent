# WenCe AI 后端环境变量配置
# 复制此文件为 .env 并填入你的真实密钥

# ============== AI 模型配置 ==============

# OpenAI / 兼容接口
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o

# 智谱 AI
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_DEFAULT_MODEL=glm-4.7

# ============== 服务配置 ==============
DEBUG=true
PORT=3880

# SQLite 数据库配置（嵌入式，无需用户安装）
# 数据将存储在 data/wence_ai.db 文件中
DATABASE_URL=sqlite+aiosqlite:///./data/wence_ai.db
