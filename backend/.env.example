# LangSmith 监控配置（可选，不配置不影响项目运行）
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT="WordAgent"

# 可选：指定 dev 使用的模型（不填时走 auto）
# LANGGRAPH_DEV_MODEL=qwen-max

# ========== WordAgent 上下文压缩（已接入代码） ==========
# 总上下文上限估算（达到该规模时会触发上下文压缩，默认200k）
WORDAGENT_MAX_CONTEXT_TOKENS=50000

# ========== Agent 轮次控制（已接入代码） ==========
# Agent 总轮次上限（每轮 = 1次 LLM 调用，无论是否调用工具，默认 20）
WORDAGENT_AGENT_RECURSION_LIMIT=20

# ========== MCP 输出防膨胀（已接入代码） ==========
# 前端展示的 MCP 结果预览最大字符数
WORDAGENT_MCP_PREVIEW_MAX_CHARS=4000
# 注入给模型的 MCP 工具结果最大字符数
WORDAGENT_MCP_MODEL_MAX_CHARS=12000

# ========== 上下文压缩（LLMChainExtractor 语义压缩） ==========
# 是否启用 LLMChainExtractor 语义压缩（true/false）
WORDAGENT_ENABLE_LLM_CHAIN_EXTRACTOR=true
# LLMChainExtractor 保留末尾原始对话条数（最新消息不压缩）
WORDAGENT_EXTRACTOR_KEEP_RECENT_MESSAGES=4
# LLMChainExtractor 最大处理的消息条数（防止压缩调用过慢）
WORDAGENT_EXTRACTOR_MAX_SOURCE_MESSAGES=16