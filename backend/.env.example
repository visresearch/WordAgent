# LangSmith 监控配置（可选，不配置不影响项目运行）
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_api_key_here
LANGSMITH_PROJECT=WordAgent

# LangSmith 评估配置（可选，不配置不影响项目运行）
LANGSMITH_EVALUATION_PROJECT=WordAgent_evaluation
LANGSMITH_DATASET_NAME=WordAgent_dataset
EVAL_OPENAI_MODEL=gpt-5.1
EVAL_OPENAI_API_KEY=your_api_key_here
EVAL_OPENAI_BASE_URL=
EVAL_CONCURRENCY=5

# ========== Agent 轮次控制 ==========
# Agent 总轮次上限（每轮 = 1次 LLM 调用，无论是否调用工具，默认 25）
WORDAGENT_AGENT_RECURSION_LIMIT=25

# ========== MCP 输出防膨胀 ==========
# 前端展示的 MCP 结果预览最大字符数
WORDAGENT_MCP_PREVIEW_MAX_CHARS=100000
# 注入给模型的 MCP 工具结果最大字符数
WORDAGENT_MCP_MODEL_MAX_CHARS=100000

# ========== 上传文件处理配置 ==========
# 注入到 LLM 上下文的文本最大字符数（约 25K tokens）
MAX_TEXT_CHARS=50000

# ========== WordAgent 上下文上限 ==========
# 总上下文上限估算（默认200k token）
WORDAGENT_MAX_CONTEXT_TOKENS=200000

# ========== 上下文压缩（Claude Code 风格两级压缩） ==========
# LLMChainExtractor 语义压缩（默认禁用，与重量压缩二选一）
WORDAGENT_ENABLE_LLM_CHAIN_EXTRACTOR=false            # 启用 LLMChainExtractor 语义压缩（与重量压缩重叠时仅其一会生效，默认 false 不启用）
WORDAGENT_EXTRACTOR_KEEP_RECENT_MESSAGES=4            # 语义压缩时始终保留的最近原始消息数
WORDAGENT_EXTRACTOR_MAX_SOURCE_MESSAGES=16            # 语义压缩触发时可压缩的最大历史消息数

# 轻量压缩 (Light Compact) - 无 LLM 调用，清除旧工具结果
WORDAGENT_ENABLE_LIGHT_COMPACT=true                   # 启用轻量压缩（仅清除旧工具结果，不调用 LLM，总是默认启用）
WORDAGENT_LIGHT_COMPACT_PROTECT_TOKENS=40000          # 轻量压缩时保护的最近工具结果的最大 token 数
WORDAGENT_LIGHT_COMPACT_MIN_TOOL_RESULTS=3            # 轻量压缩时始终保留的最近工具结果数量
WORDAGENT_LIGHT_COMPACT_MIN_SAVINGS=20000             # 轻量压缩至少需要节省的最小 token 数，达不到时不压缩

# 重量压缩 (Heavy Compact) - LLM 生成 9 段结构化摘要
WORDAGENT_ENABLE_HEAVY_COMPACT=true                   # 启用重量压缩（LLM 结构化摘要，推荐开启）
WORDAGENT_HEAVY_COMPACT_TRIGGER_PCT=83                # 重量压缩触发阈值（占当前上下文 token 上限的百分比，超出时压缩），如 83 表示 83%
WORDAGENT_HEAVY_COMPACT_RESERVE_OUTPUT=20000          # 压缩时为后续输出保留的 token 数（避免模型答复时溢出）
WORDAGENT_HEAVY_COMPACT_MAX_OUTPUT=20000              # LLM 结构化摘要的输出最大 token 数
WORDAGENT_HEAVY_COMPACT_KEEP_RECENT=4                 # 压缩后始终保留的最近原始消息条数
